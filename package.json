{
  "name": "@pasty/aira2-plugin",
  "private": true,
  "version": "1.0.0",
  "description": "Pasty plugin that detects download links and submits them to aria2 RPC.",
  "scripts": {
    "clean": "rm -rf dist",
    "dev": "vite --host 127.0.0.1 --open /src/features/aria2-download/index.html",
    "dev:renderer": "vite --host 127.0.0.1 --open /src/features/aria2-download/index.html",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint src tests --ext .ts,.vue,.js,.cjs",
    "build:runtime": "node ./scripts/build-runtime.mjs",
    "build:ui": "node ./scripts/build-ui.mjs",
    "verify:build": "node ./scripts/verify-build.mjs",
    "build": "npm run clean && npm run build:runtime && npm run build:ui && npm run verify:build",
    "test": "node --test ./tests/**/*.test.cjs"
  },
  "dependencies": {
    "@pasty/plugin-sdk": "^0.4.0",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "@vitejs/plugin-vue": "^5.2.1",
    "esbuild": "^0.25.0",
    "eslint": "^8.57.1",
    "eslint-plugin-vue": "^9.33.0",
    "typescript": "^6.0.3",
    "vite": "^5.4.14",
    "vue-eslint-parser": "^9.4.3",
    "vue-tsc": "^3.1.3"
  }
}
